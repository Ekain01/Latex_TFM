    \field{pages}{168\bibrangedash 177}
    \field{title}{Accounting for Environmental Conditions in Data-Driven Wind
  Turbine Power Models}
    \field{volume}{14}
    \field{journaltitle}{IEEE Transactions on Sustainable Energy}
    \field{month}{01}
    \field{year}{2023}
  \endentry

  \entry{Shi2021}{article}{}{}
