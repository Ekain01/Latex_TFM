    \field{note}{PCA analisis para turbinas}
    \field{pages}{349\bibrangedash 361}
    \field{title}{Detecting Anomaly Classification Using PCA-Kmeans and
  Ensembled Classifier for Wind Turbines}
    \field{volume}{11}
    \field{journaltitle}{IEEE Open Access Journal of Power and Energy}
