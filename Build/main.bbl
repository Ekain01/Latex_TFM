  distintas turbinas}
    \field{pages}{442\bibrangedash 452}
    \field{title}{Clustering Wind Turbines for SCADA Data-Based Fault
  Detection}
    \field{volume}{14}
    \field{journaltitle}{IEEE Transactions on Sustainable Energy}
